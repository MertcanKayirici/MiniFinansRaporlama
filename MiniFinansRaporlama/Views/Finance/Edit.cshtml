@model MiniFinansRaporlama.Models.Transactions

@{
    // Page title displayed in the layout
    ViewBag.Title = "İşlem Düzenle";
}

@section Styles {
    <style>
        /* Page title styling */
        .page-title {
            font-weight: 800;
            letter-spacing: -.4px;
            color: #0f172a;
        }

        /* Subtitle under title */
        .page-subtitle {
            color: #64748b;
        }

        /* Main container card */
        .soft-card {
            border-radius: 24px;
            border: 1px solid #e7edf5;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
        }

        /* Header layout (title + back button) */
        .edit-topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        /* Summary cards showing current values */
        .edit-summary-card {
            border-radius: 20px;
            border: 1px solid #ebf1f7;
            background: #fff;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
            padding: 1.2rem;
            height: 100%;
        }

        /* Summary label */
        .summary-label {
            color: #64748b;
            font-size: .85rem;
            margin-bottom: .35rem;
        }

        /* Summary value */
        .summary-value {
            font-size: 1.2rem;
            font-weight: 800;
            margin-bottom: 0;
            color: #0f172a;
        }

        /* Section title */
        .section-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: .2rem;
        }

        /* Section subtitle */
        .section-subtitle {
            color: #64748b;
            font-size: .88rem;
            margin-bottom: 0;
        }

        /* Form field container */
        .detail-field {
            border: 1px solid #e7edf5;
            border-radius: 18px;
            background: #fff;
            padding: 1rem;
            height: 100%;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.03);
        }

        /* Field label */
        .detail-label {
            font-size: .82rem;
            font-weight: 700;
            color: #64748b;
            margin-bottom: .45rem;
            text-transform: uppercase;
            letter-spacing: .3px;
        }

        /* Input and select base styles */
        .form-control,
        .form-select {
            border-radius: 14px;
            min-height: 48px;
            border: 1px solid #dbe4f0;
            box-shadow: none;
            font-weight: 500;
        }

            /* Focus styles */
            .form-control:focus,
            .form-select:focus {
                border-color: #6366f1;
                box-shadow: 0 0 0 .2rem rgba(99,102,241,.12);
            }

        /* Textarea styling */
        textarea.form-control {
            min-height: 130px;
            resize: vertical;
        }

        /* Description preview box */
        .description-box {
            border: 1px solid #e7edf5;
            border-radius: 18px;
            background: #f8fafc;
            min-height: 120px;
            padding: 1rem;
            color: #334155;
        }

        /* Action buttons container */
        .action-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            margin-top: 1.75rem;
        }

            /* Action buttons */
            .action-wrap .btn {
                min-width: 140px;
                border-radius: 14px;
                font-weight: 700;
            }

        /* Amount highlight styles */
        .highlight-amount-income {
            color: #16a34a;
        }

        .highlight-amount-expense {
            color: #dc2626;
        }

        /* Badge styles for transaction type */
        .detail-badge {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .55rem .9rem;
            border-radius: 999px;
            font-size: .85rem;
            font-weight: 700;
        }

        .badge-income-soft {
            background: rgba(34, 197, 94, 0.12);
            color: #15803d;
        }

        .badge-expense-soft {
            background: rgba(239, 68, 68, 0.12);
            color: #b91c1c;
        }

        /* Validation summary box */
        .validation-summary-errors {
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.14);
            border-radius: 16px;
            padding: .9rem 1rem;
            margin-bottom: 1rem;
            color: #b91c1c;
        }

        /* Validation text */
        .field-validation-error,
        .text-danger {
            font-size: .82rem;
            font-weight: 600;
        }

        /* Responsive adjustments */
        @@media (max-width: 576px) {
            .action-wrap .btn {
                width: 100%;
            }
        }
    </style>
}

<!-- PAGE HEADER -->
<div class="edit-topbar">
    <div>
        <h2 class="page-title mb-1">İşlem Düzenle</h2>
        <p class="page-subtitle mb-0">
            Update the selected transaction details.
        </p>
    </div>

    <!-- Back navigation -->
    <div>
        @Html.ActionLink("Listeye Dön", "Index", null, new { @class = "btn btn-outline-secondary rounded-3 px-4" })
    </div>
</div>

<!-- MAIN CONTAINER -->
<div class="soft-card p-4 p-md-4">

    <!-- CURRENT VALUES SUMMARY -->
    <div class="row g-3 mb-4">

        <!-- Current amount -->
        <div class="col-12 col-md-4">
            <div class="edit-summary-card">
                <div class="summary-label">Mevcut Tutar</div>
                <h4 class="summary-value @(Model.Type == "Gelir" ? "highlight-amount-income" : "highlight-amount-expense")">
                    @Model.Amount.ToString("N2") ₺
                </h4>
            </div>
        </div>

        <!-- Current type -->
        <div class="col-12 col-md-4">
            <div class="edit-summary-card">
                <div class="summary-label">Mevcut Tip</div>
                <div class="mt-2">
                    @if (Model.Type == "Gelir")
                    {
                        <span class="detail-badge badge-income-soft">⬆ Gelir</span>
                    }
                    else
                    {
                        <span class="detail-badge badge-expense-soft">⬇ Gider</span>
                    }
                </div>
            </div>
        </div>

        <!-- Current category -->
        <div class="col-12 col-md-4">
            <div class="edit-summary-card">
                <div class="summary-label">Mevcut Kategori</div>
                <h4 class="summary-value">
                    @(string.IsNullOrWhiteSpace(Model.Category) ? "Diğer" : Model.Category)
                </h4>
            </div>
        </div>
    </div>

    <!-- FORM HEADER -->
    <div class="mb-4">
        <h5 class="section-title">Düzenleme Formu</h5>
        <p class="section-subtitle">
            Modify fields below and save changes.
        </p>
    </div>

    <!-- EDIT FORM -->
    @using (Html.BeginForm("Edit", "Finance", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        // Hidden fields used to preserve entity identity and creation date
        @Html.HiddenFor(x => x.Id)
        @Html.HiddenFor(x => x.CreatedAt)

        // Validation summary
        @Html.ValidationSummary(false, "", new { })

        <div class="row g-3">

            <!-- Date field -->
            <div class="col-12 col-md-6">
                <div class="detail-field">
                    <div class="detail-label">Tarih</div>
                    @Html.TextBoxFor(x => x.Date, "{0:yyyy-MM-dd}", new
                    {
                        @class = "form-control",
                        type = "date"
                    })
                    @Html.ValidationMessageFor(x => x.Date, "", new { @class = "text-danger mt-2 d-block" })
                </div>
            </div>

            <!-- Amount field -->
            <div class="col-12 col-md-6">
                <div class="detail-field">
                    <div class="detail-label">Tutar</div>
                    @Html.TextBoxFor(x => x.Amount, new
                    {
                        @class = "form-control",
                        type = "text",
                        inputmode = "decimal",
                        placeholder = "Tutar giriniz"
                    })
                    @Html.ValidationMessageFor(x => x.Amount, "", new { @class = "text-danger mt-2 d-block" })
                </div>
            </div>

            <!-- Category field -->
            <div class="col-12 col-md-6">
                <div class="detail-field">
                    <div class="detail-label">Kategori</div>
                    @Html.DropDownListFor(
                        x => x.Category,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Maaş", Value = "Maaş" },
                            new SelectListItem { Text = "Ek Gelir", Value = "Ek Gelir" },
                            new SelectListItem { Text = "Market", Value = "Market" },
                            new SelectListItem { Text = "Fatura", Value = "Fatura" },
                            new SelectListItem { Text = "Ulaşım", Value = "Ulaşım" },
                            new SelectListItem { Text = "Eğitim", Value = "Eğitim" },
                            new SelectListItem { Text = "Diğer", Value = "Diğer" }
                        },
                        "Seçiniz",
                        new { @class = "form-select" }
                    )
                    @Html.ValidationMessageFor(x => x.Category, "", new { @class = "text-danger mt-2 d-block" })
                </div>
            </div>

            <!-- Type field -->
            <div class="col-12 col-md-6">
                <div class="detail-field">
                    <div class="detail-label">Tip</div>
                    @Html.DropDownListFor(
                        x => x.Type,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Gelir", Value = "Gelir" },
                            new SelectListItem { Text = "Gider", Value = "Gider" }
                        },
                        "Seçiniz",
                        new { @class = "form-select" }
                    )
                    @Html.ValidationMessageFor(x => x.Type, "", new { @class = "text-danger mt-2 d-block" })
                </div>
            </div>

            <!-- Description field -->
            <div class="col-12">
                <div class="detail-field">
                    <div class="detail-label">Açıklama</div>
                    @Html.TextAreaFor(x => x.Description, new
                    {
                        @class = "form-control",
                        rows = 5,
                        placeholder = "İşlem açıklaması giriniz"
                    })
                    @Html.ValidationMessageFor(x => x.Description, "", new { @class = "text-danger mt-2 d-block" })
                </div>
            </div>
        </div>

        <!-- ACTION BUTTONS -->
        <div class="action-wrap">
            <button type="submit" class="btn btn-primary">Kaydet</button>
            @Html.ActionLink("İptal", "Index", null, new { @class = "btn btn-outline-dark" })
        </div>
    }
</div>