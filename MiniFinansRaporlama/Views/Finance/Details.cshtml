@model MiniFinansRaporlama.Models.Transactions

@{
    // Page title used in browser tab and layout
    ViewBag.Title = "İşlem Detayı";
}

<!-- Page header and back button -->
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <!-- Main page title -->
        <h2 class="mb-1">İşlem Detayı</h2>

        <!-- Short page description -->
        <p class="text-muted mb-0">İşleme ait tüm bilgileri buradan görüntüleyebilirsin.</p>
    </div>

    <!-- Button to return to transaction list -->
    <div>
        @Html.ActionLink("Listeye Dön", "Index", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>

<!-- Main card showing transaction details -->
<div class="card shadow-sm border-0">
    <div class="card-body p-4">

        <!-- Grid layout for transaction fields -->
        <div class="row g-3">

            <!-- Transaction date -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Tarih</label>

                <!-- Read-only display area -->
                <div class="form-control bg-light">
                    @(Model.Amount.ToString("N2") + " ₺")
                </div>
            </div>

            <!-- Transaction category -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Kategori</label>

                <!-- Category value from model -->
                <div class="form-control bg-light">
                    @Model.Category
                </div>
            </div>

            <!-- Transaction type -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Tip</label>

                <!-- Badge changes based on transaction type -->
                <div class="form-control bg-light">
                    @if (Model.Type == "Gelir")
                    {
                        <span class="badge text-bg-success">Gelir</span>
                    }
                    else
                    {
                        <span class="badge text-bg-danger">Gider</span>
                    }
                </div>
            </div>

            <!-- Transaction amount -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Tutar</label>

                <!-- Amount displayed in currency format -->
                <div class="form-control bg-light">
                    @(Model.Amount.ToString("N2") + " ₺")
                </div>
            </div>

            <!-- Record creation date -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Oluşturulma Tarihi</label>

                <!-- CreatedAt value display -->
                <div class="form-control bg-light">
                    @(Model.Amount.ToString("N2") + " ₺")
                </div>
            </div>

            <!-- Record last update date -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Güncellenme Tarihi</label>

                <!-- UpdatedAt value display if available -->
                <div class="form-control bg-light">
                    @(Model.UpdatedAt != null ? Model.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm") : "")
                </div>
            </div>

            <!-- Transaction description -->
            <div class="col-12">
                <label class="form-label fw-semibold">Açıklama</label>

                <!-- Multi-line description display -->
                <div class="form-control bg-light" style="min-height: 100px;">
                    @Model.Description
                </div>
            </div>

        </div>

        <!-- Action buttons -->
        <div class="d-flex flex-column flex-sm-row gap-2 mt-4">

            <!-- Button to navigate to edit page -->
            @Html.ActionLink("Düzenle", "Edit", new { id = Model.Id }, new { @class = "btn btn-warning" })

            <!-- Button to navigate to delete page -->
            @Html.ActionLink("Sil", "Delete", new { id = Model.Id }, new { @class = "btn btn-danger" })

            <!-- Button to return to list page -->
            @Html.ActionLink("Listeye Dön", "Index", null, new { @class = "btn btn-outline-dark" })
        </div>

    </div>
</div>