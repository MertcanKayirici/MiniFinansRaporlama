@model MiniFinansRaporlama.Models.Transactions

@{
    // Page title displayed in the shared layout
    ViewBag.Title = "Yeni İşlem Ekle";
}

@section Styles {
    <style>
        /* Main page title styling */
        .page-title {
            font-weight: 800;
            letter-spacing: -.4px;
            color: #0f172a;
        }

        /* Subtitle text below the page title */
        .page-subtitle {
            color: #64748b;
        }

        /* Main outer card container */
        .soft-card {
            border-radius: 24px;
            border: 1px solid #e7edf5;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
        }

        /* Section title styling */
        .section-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: .2rem;
        }

        /* Section subtitle styling */
        .section-subtitle {
            color: #64748b;
            font-size: .88rem;
            margin-bottom: 0;
        }

        /* Form wrapper card */
        .form-shell {
            border: 1px solid #e7edf5;
            border-radius: 20px;
            background: #ffffff;
            padding: 1.25rem;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
        }

        /* Form label styling */
        .form-label {
            font-weight: 700 !important;
            color: #334155;
            margin-bottom: .55rem;
        }

        /* Shared input and select styling */
        .form-control,
        .form-select {
            min-height: 52px;
            border-radius: 14px;
            border: 1px solid #dbe4ee;
            background-color: #fff;
            box-shadow: none;
            transition: all .2s ease;
        }

        /* Textarea specific sizing */
        textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

        /* Focus state for form elements */
        .form-control:focus,
        .form-select:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 .2rem rgba(99, 102, 241, 0.12);
        }

        /* Validation message styling */
        .text-danger.small,
        .field-validation-error {
            display: block;
            margin-top: .4rem;
            font-size: .82rem;
            font-weight: 600;
        }

        /* Validation summary container spacing */
        .validation-summary-errors,
        .validation-summary-valid {
            margin-bottom: 1rem;
        }

        /* Validation summary error box */
        .validation-summary-errors {
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.18);
            color: #b91c1c;
            border-radius: 16px;
            padding: 1rem 1rem .85rem 1rem;
        }

            /* Validation summary list styling */
            .validation-summary-errors ul {
                margin: 0;
                padding-left: 1.2rem;
            }

        /* Informational cards shown above the form */
        .mini-info-card {
            border-radius: 18px;
            border: 1px solid #e7edf5;
            background: linear-gradient(135deg, #f8fbff 0%, #ffffff 100%);
            padding: 1rem;
            height: 100%;
        }

        /* Informational card title */
        .mini-info-title {
            font-size: .85rem;
            color: #64748b;
            margin-bottom: .35rem;
            font-weight: 600;
        }

        /* Informational card value text */
        .mini-info-value {
            font-size: 1rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0;
        }

        /* Action button container */
        .action-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
            margin-top: 1.75rem;
        }

            /* Shared styling for form action buttons */
            .action-wrap .btn,
            .action-wrap input[type="submit"] {
                min-width: 150px;
                min-height: 48px;
                border-radius: 14px;
                font-weight: 700;
            }

        /* Save button emphasis */
        .save-btn {
            box-shadow: 0 10px 24px rgba(34, 197, 94, 0.18);
        }

        /* Top navigation action button */
        .top-action-btn {
            border-radius: 14px;
            padding: .75rem 1.1rem;
            font-weight: 700;
        }

        /* Responsive layout for smaller screens */
        @@media (max-width: 576px) {
            .action-wrap .btn,
            .action-wrap input[type="submit"],
            .top-action-btn {
                width: 100%;
            }
        }
    </style>
}

<!-- Page header and quick navigation -->
<div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3 mb-4">
    <div>
        <h2 class="page-title mb-1">Yeni İşlem Ekle</h2>
        <p class="page-subtitle mb-0">Yeni gelir veya gider kaydını hızlı ve düzenli şekilde oluşturabilirsin.</p>
    </div>

    <div>
        <!-- Navigate back to transaction list -->
        @Html.ActionLink("Listeye Dön", "Index", null, new { @class = "btn btn-outline-secondary top-action-btn" })
    </div>
</div>

<!-- Main content card -->
<div class="soft-card p-4">
    <!-- Informational summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="mini-info-card">
                <div class="mini-info-title">İşlem Türü</div>
                <p class="mini-info-value">Gelir veya gider ekle</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="mini-info-card">
                <div class="mini-info-title">Kategori</div>
                <p class="mini-info-value">Finans hareketini sınıflandır</p>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="mini-info-card">
                <div class="mini-info-title">Kayıt</div>
                <p class="mini-info-value">Düzenli takip için anında kaydet</p>
            </div>
        </div>
    </div>

    <!-- Form section heading -->
    <div class="mb-4">
        <h5 class="section-title">İşlem Formu</h5>
        <p class="section-subtitle">Aşağıdaki alanları doldurarak yeni finans kaydı oluştur.</p>
    </div>

    <!-- Transaction creation form -->
    <div class="form-shell">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            <!-- Validation summary for model errors -->
            @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

            <div class="row g-3">
                <!-- Transaction date field -->
                <div class="col-12 col-md-6">
                    @Html.LabelFor(model => model.Date, new { @class = "form-label" })

                    @Html.TextBoxFor(model => model.Date, "{0:yyyy-MM-dd}", new
                    {
                        @class = "form-control",
                        type = "date"
                    })

                    @Html.ValidationMessageFor(model => model.Date, "", new { @class = "text-danger small" })
                </div>

                <!-- Category selection field -->
                <div class="col-12 col-md-6">
                    @Html.LabelFor(model => model.Category, new { @class = "form-label" })

                    @Html.DropDownListFor(
                        model => model.Category,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Maaş", Value = "Maaş" },
                            new SelectListItem { Text = "Ek Gelir", Value = "Ek Gelir" },
                            new SelectListItem { Text = "Market", Value = "Market" },
                            new SelectListItem { Text = "Fatura", Value = "Fatura" },
                            new SelectListItem { Text = "Ulaşım", Value = "Ulaşım" },
                            new SelectListItem { Text = "Eğitim", Value = "Eğitim" },
                            new SelectListItem { Text = "Diğer", Value = "Diğer" }
                        },
                        "Kategori Seçiniz",
                        new { @class = "form-select" }
                    )

                    @Html.ValidationMessageFor(model => model.Category, "", new { @class = "text-danger small" })
                </div>

                <!-- Transaction type field -->
                <div class="col-12 col-md-6">
                    @Html.LabelFor(model => model.Type, new { @class = "form-label" })

                    @Html.DropDownListFor(
                        model => model.Type,
                        new List<SelectListItem>
                        {
                            new SelectListItem { Text = "Gelir", Value = "Gelir" },
                            new SelectListItem { Text = "Gider", Value = "Gider" }
                        },
                        "Seçiniz",
                        new { @class = "form-select" }
                    )

                    @Html.ValidationMessageFor(model => model.Type, "", new { @class = "text-danger small" })
                </div>

                <!-- Amount input field -->
                <div class="col-12 col-md-6">
                    @Html.LabelFor(model => model.Amount, new { @class = "form-label" })

                    @Html.TextBoxFor(model => model.Amount, new
                    {
                        @class = "form-control",
                        placeholder = "Tutar giriniz"
                    })

                    @Html.ValidationMessageFor(model => model.Amount, "", new { @class = "text-danger small" })
                </div>

                <!-- Description input field -->
                <div class="col-12">
                    @Html.LabelFor(model => model.Description, new { @class = "form-label" })

                    @Html.TextAreaFor(model => model.Description, new
                    {
                        @class = "form-control",
                        rows = "5",
                        placeholder = "İşlem hakkında kısa bir açıklama giriniz"
                    })

                    @Html.ValidationMessageFor(model => model.Description, "", new { @class = "text-danger small" })
                </div>
            </div>

            <!-- Form actions -->
            <div class="action-wrap">
                <input type="submit" value="Kaydet" class="btn btn-success save-btn" />
                @Html.ActionLink("Vazgeç", "Index", null, new { @class = "btn btn-outline-dark" })
            </div>
        }
    </div>
</div>