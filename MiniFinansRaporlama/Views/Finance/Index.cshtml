@model IEnumerable<MiniFinansRaporlama.Models.Transactions>

@{
    // Page title displayed in the shared layout
    ViewBag.Title = "Finansal İşlemler";

    // Recent transactions displayed in the side panel
    var sonIslemler = ViewBag.SonIslemler as List<MiniFinansRaporlama.Models.Transactions>;

    // Recent audit logs displayed in the activity panel
    var sonLoglar = ViewBag.SonLoglar as List<MiniFinansRaporlama.Models.Logs>;

    // Top expense categories used in the summary section
    var topCategories = ViewBag.TopCategories as List<MiniFinansRaporlama.Controllers.CategorySummaryViewModel>;

    // Preserve selected start date in the filter form
    string currentStartDate = ViewBag.StartDate != null
        ? ((DateTime)ViewBag.StartDate).ToString("yyyy-MM-dd")
        : "";

    // Preserve selected end date in the filter form
    string currentEndDate = ViewBag.EndDate != null
        ? ((DateTime)ViewBag.EndDate).ToString("yyyy-MM-dd")
        : "";

    // Preserve selected category in the filter form
    string currentCategory = ViewBag.Category != null
        ? ViewBag.Category.ToString()
        : "";

    // Default text shown when no filters are active
    string filterSummary = "Tüm kayıtlar gösteriliyor";

    // Build a readable filter summary when at least one filter is active
    if (!string.IsNullOrWhiteSpace(currentCategory) || !string.IsNullOrWhiteSpace(currentStartDate) || !string.IsNullOrWhiteSpace(currentEndDate))
    {
        filterSummary = "Filtre aktif";

        if (!string.IsNullOrWhiteSpace(currentCategory))
        {
            filterSummary += " | Kategori: " + currentCategory;
        }

        if (!string.IsNullOrWhiteSpace(currentStartDate) || !string.IsNullOrWhiteSpace(currentEndDate))
        {
            filterSummary += " | Tarih: " +
                             (string.IsNullOrWhiteSpace(currentStartDate) ? "-" : currentStartDate) +
                             " / " +
                             (string.IsNullOrWhiteSpace(currentEndDate) ? "-" : currentEndDate);
        }
    }
}

@section Styles {
    <style>
        /* Main page title styling */
        .page-title {
            font-weight: 800;
            letter-spacing: -.4px;
        }

        /* Subtitle text shown below the page title */
        .page-subtitle {
            color: #64748b;
        }

        /* Reusable soft card used in side sections */
        .soft-card {
            border-radius: 22px;
            border: 1px solid #e7edf5;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
        }

        /* Section heading style */
        .section-title {
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: .2rem;
        }

        /* Secondary section description text */
        .section-subtitle {
            color: #64748b;
            font-size: .88rem;
            margin-bottom: 0;
        }

        /* Action button area in the hero section */
        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: .75rem;
        }

        /* Shared style for hero action buttons */
        .hero-btn {
            min-width: 140px;
            justify-content: center;
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            border-radius: 14px;
            font-weight: 700;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        }

        /* Filter panel container */
        .filter-panel {
            border-radius: 22px;
            border: 1px solid #e7edf5;
            background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
        }

        /* Dashboard summary card */
        .summary-card {
            position: relative;
            overflow: hidden;
            border-radius: 20px;
            border: 1px solid #ebf1f7;
            background: #fff;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
        }

            /* Decorative top line for summary cards */
            .summary-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 4px;
            }

        /* Income summary accent color */
        .summary-income::before {
            background: linear-gradient(90deg, #22c55e, #16a34a);
        }

        /* Expense summary accent color */
        .summary-expense::before {
            background: linear-gradient(90deg, #ef4444, #dc2626);
        }

        /* Balance summary accent color */
        .summary-balance::before {
            background: linear-gradient(90deg, #3b82f6, #2563eb);
        }

        /* Transaction count summary accent color */
        .summary-count::before {
            background: linear-gradient(90deg, #8b5cf6, #7c3aed);
        }

        /* Mini summary accent color */
        .mini-summary::before {
            background: linear-gradient(90deg, #06b6d4, #3b82f6);
        }

        /* Mini log accent color */
        .mini-log::before {
            background: linear-gradient(90deg, #f59e0b, #f97316);
        }

        /* Icon container inside summary cards */
        .summary-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: bold;
        }

        /* Income icon styling */
        .icon-income {
            background: rgba(34, 197, 94, 0.12);
            color: #16a34a;
        }

        /* Expense icon styling */
        .icon-expense {
            background: rgba(239, 68, 68, 0.12);
            color: #dc2626;
        }

        /* Balance icon styling */
        .icon-balance {
            background: rgba(59, 130, 246, 0.12);
            color: #2563eb;
        }

        /* Count icon styling */
        .icon-count {
            background: rgba(139, 92, 246, 0.12);
            color: #7c3aed;
        }

        /* Mini metric icon styling */
        .icon-mini {
            background: rgba(14, 165, 233, 0.12);
            color: #0369a1;
        }

        /* Log metric icon styling */
        .icon-log {
            background: rgba(245, 158, 11, 0.14);
            color: #c2410c;
        }

        /* Label text used in summary cards */
        .summary-label {
            color: #64748b;
            font-size: .86rem;
            margin-bottom: .2rem;
        }

        /* Main numeric value style */
        .summary-value {
            font-size: 1.4rem;
            font-weight: 800;
            margin-bottom: 0;
        }

        /* Supporting text under metric values */
        .summary-sub {
            color: #64748b;
            font-size: .82rem;
            margin-top: .3rem;
        }

        /* Chart card container */
        .chart-card {
            border-radius: 22px;
            border: 1px solid #e7edf5;
            background: #fff;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
        }

        /* Base wrapper for charts */
        .chart-wrapper {
            position: relative;
            width: 100%;
            min-height: 300px;
            height: 300px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Larger chart wrapper for monthly analysis */
        .chart-wrapper-lg {
            min-height: 360px;
            height: 360px;
        }

        /* Force canvas to fill wrapper */
        .chart-wrapper canvas {
            width: 100% !important;
            height: 100% !important;
        }

        /* Empty state container */
        .empty-state {
            text-align: center;
            padding: 2rem 1rem;
        }

        /* Empty state icon style */
        .empty-icon {
            font-size: 2rem;
            margin-bottom: .6rem;
        }

        /* Card-like item used in recent transaction list */
        .side-list-item {
            border: 1px solid #edf2f7;
            border-radius: 18px;
            background: #f8fafc;
            padding: 1rem;
        }

            /* Spacing between recent transaction items */
            .side-list-item + .side-list-item {
                margin-top: .8rem;
            }

        /* Row layout for top category list */
        .top-category-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            padding: .85rem 0;
            border-bottom: 1px dashed #e5e7eb;
        }

            /* Remove divider from the last category item */
            .top-category-row:last-child {
                border-bottom: none;
            }

        /* Timeline item used for activity log */
        .activity-item {
            position: relative;
            padding-left: 1.1rem;
            margin-bottom: 1rem;
        }

            /* Dot marker for activity timeline */
            .activity-item::before {
                content: "";
                position: absolute;
                left: 0;
                top: .45rem;
                width: 10px;
                height: 10px;
                border-radius: 50%;
            }

        /* Create action marker */
        .activity-create::before {
            background: #22c55e;
        }

        /* Update action marker */
        .activity-update::before {
            background: #f59e0b;
        }

        /* Delete action marker */
        .activity-delete::before {
            background: #ef4444;
        }

        /* Filter summary badge style */
        .filter-summary-badge {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .55rem .85rem;
            border-radius: 999px;
            background: #eef4ff;
            color: #1d4ed8;
            font-size: .85rem;
            font-weight: 600;
        }

        /* Main table shell container */
        .table-shell {
            border-radius: 22px;
            overflow: hidden;
            border: 1px solid #e7edf5;
            background: #fff;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
        }

        /* Table header style */
        .table thead th {
            background: #f8fbff;
            color: #334155;
            font-weight: 700;
            white-space: nowrap;
            border-bottom: 1px solid #e7edf5;
        }

        /* Hover effect for table rows */
        .table tbody tr:hover {
            background: #fbfdff;
        }

        /* Vertical action button stack */
        .action-stack {
            display: flex;
            flex-direction: column;
            gap: .45rem;
        }

            /* Shared styling for action buttons */
            .action-stack .btn {
                border-radius: 12px;
                font-weight: 600;
            }

        /* Small metric badge used across sections */
        .metric-chip {
            display: inline-flex;
            align-items: center;
            padding: .35rem .65rem;
            border-radius: 999px;
            font-size: .78rem;
            font-weight: 700;
        }

        /* Success chip */
        .chip-success {
            background: rgba(34, 197, 94, 0.12);
            color: #15803d;
        }

        /* Danger chip */
        .chip-danger {
            background: rgba(239, 68, 68, 0.12);
            color: #b91c1c;
        }

        /* Warning chip */
        .chip-warning {
            background: rgba(245, 158, 11, 0.12);
            color: #b45309;
        }

        /* Info chip */
        .chip-info {
            background: rgba(59, 130, 246, 0.12);
            color: #1d4ed8;
        }

        /* SweetAlert popup customization */
        .finance-swal-popup {
            border-radius: 24px !important;
            padding: 1.4rem !important;
            border: 1px solid #e7edf5 !important;
            box-shadow: 0 30px 80px rgba(15, 23, 42, 0.18) !important;
        }

        /* SweetAlert title customization */
        .finance-swal-title {
            font-weight: 800 !important;
            color: #0f172a !important;
            font-size: 1.5rem !important;
        }

        /* Shared styles for SweetAlert buttons */
        .finance-swal-confirm,
        .finance-swal-cancel {
            min-width: 140px;
            min-height: 46px;
            border-radius: 14px !important;
            font-weight: 700 !important;
            border: none !important;
            padding: .75rem 1rem !important;
            margin: 0 .25rem !important;
        }

        /* Confirm button style */
        .finance-swal-confirm {
            background: #dc2626 !important;
            color: #fff !important;
            box-shadow: 0 10px 24px rgba(220, 38, 38, 0.20) !important;
        }

        /* Cancel button style */
        .finance-swal-cancel {
            background: #e2e8f0 !important;
            color: #0f172a !important;
        }

        /* Ensure modal appears above all page content */
        div:where(.swal2-container) {
            z-index: 99999 !important;
        }

        /* Larger chart sizes for wide screens */
        @@media (min-width: 1200px) {
            .chart-wrapper {
                min-height: 340px;
                height: 340px;
            }

            .chart-wrapper-lg {
                min-height: 390px;
                height: 390px;
            }
        }
    </style>
}

<!-- Page header and primary actions -->
<div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3 mb-4">
    <div>
        <h2 class="page-title mb-1">Finansal İşlemler</h2>
        <p class="page-subtitle mb-0">Gelir ve gider kayıtlarını modern finans panelinden yönetebilirsin.</p>
    </div>

    <div class="hero-actions">
        @Html.ActionLink("➕ Yeni İşlem Ekle", "Create", null, new { @class = "btn btn-primary hero-btn" })

        <!-- Export current filtered data to Excel -->
        <a href="@Url.Action("ExportToExcel", "Finance", new { startDate = currentStartDate, endDate = currentEndDate, category = currentCategory })"
           class="btn btn-success hero-btn">
            📊 Excel
        </a>

        <!-- Export current filtered data to PDF -->
        <a href="@Url.Action("ExportToPdf", "Finance", new { startDate = currentStartDate, endDate = currentEndDate, category = currentCategory })"
           class="btn btn-danger hero-btn">
            📄 PDF
        </a>
    </div>
</div>

<!-- Filter section -->
<div class="filter-panel p-4 mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
            <h5 class="section-title">Filtreleme</h5>
            <p class="section-subtitle">Tarih ve kategoriye göre işlemleri filtreleyebilirsin.</p>
        </div>

        <!-- Active filter summary badge -->
        <div class="filter-summary-badge">
            🔎 @filterSummary
        </div>
    </div>

    @using (Html.BeginForm("Index", "Finance", FormMethod.Get, new { @class = "row g-3 align-items-end" }))
    {
        <!-- Start date filter -->
        <div class="col-12 col-md-3">
            <label for="startDate" class="form-label fw-semibold">Başlangıç Tarihi</label>
            <input type="date" name="startDate" id="startDate" class="form-control" value="@currentStartDate" />
        </div>

        <!-- End date filter -->
        <div class="col-12 col-md-3">
            <label for="endDate" class="form-label fw-semibold">Bitiş Tarihi</label>
            <input type="date" name="endDate" id="endDate" class="form-control" value="@currentEndDate" />
        </div>

        <!-- Category filter -->
        <div class="col-12 col-md-3">
            <label for="category" class="form-label fw-semibold">Kategori</label>
            <select name="category" id="category" class="form-select">
                <option value="">Tüm Kategoriler</option>
                <option value="Maaş" @(currentCategory == "Maaş" ? "selected" : "")>Maaş</option>
                <option value="Ek Gelir" @(currentCategory == "Ek Gelir" ? "selected" : "")>Ek Gelir</option>
                <option value="Market" @(currentCategory == "Market" ? "selected" : "")>Market</option>
                <option value="Fatura" @(currentCategory == "Fatura" ? "selected" : "")>Fatura</option>
                <option value="Ulaşım" @(currentCategory == "Ulaşım" ? "selected" : "")>Ulaşım</option>
                <option value="Eğitim" @(currentCategory == "Eğitim" ? "selected" : "")>Eğitim</option>
                <option value="Diğer" @(currentCategory == "Diğer" ? "selected" : "")>Diğer</option>
            </select>
        </div>

        <!-- Filter action buttons -->
        <div class="col-12 col-md-3">
            <div class="d-grid d-sm-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">Filtrele</button>
                <a href="@Url.Action("Index", "Finance")" class="btn btn-outline-secondary px-4">Temizle</a>
            </div>
        </div>
    }
</div>

<!-- Main dashboard summary cards -->
<div id="dashboard" class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="summary-card summary-income p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Toplam Gelir</div>
                    <h4 class="summary-value text-success">@String.Format("{0:N2} ₺", ViewBag.ToplamGelir)</h4>
                    <div class="summary-sub">Filtrelenmiş toplam gelir</div>
                </div>
                <div class="summary-icon icon-income">₺</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="summary-card summary-expense p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Toplam Gider</div>
                    <h4 class="summary-value text-danger">@String.Format("{0:N2} ₺", ViewBag.ToplamGider)</h4>
                    <div class="summary-sub">Filtrelenmiş toplam gider</div>
                </div>
                <div class="summary-icon icon-expense">₺</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="summary-card summary-balance p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Net Bakiye</div>
                    <h4 class="summary-value @(ViewBag.NetBakiye >= 0 ? "text-success" : "text-danger")">
                        @String.Format("{0:N2} ₺", ViewBag.NetBakiye)
                    </h4>
                    <div class="summary-sub">Tasarruf oranı: %@ViewBag.TasarrufOrani</div>
                </div>
                <div class="summary-icon icon-balance">📈</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-sm-6 col-xl-3">
        <div class="summary-card summary-count p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Toplam İşlem</div>
                    <h4 class="summary-value">@ViewBag.IslemSayisi</h4>
                    <div class="summary-sub">Ortalama: @String.Format("{0:N2} ₺", ViewBag.OrtalamaIslemTutari)</div>
                </div>
                <div class="summary-icon icon-count">🧾</div>
            </div>
        </div>
    </div>
</div>

<!-- Secondary dashboard metric cards -->
<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="summary-card mini-summary p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Bu Ay Gelir</div>
                    <h5 class="summary-value text-success">@String.Format("{0:N2} ₺", ViewBag.ThisMonthIncome)</h5>
                    <div class="summary-sub">Değişim: %@ViewBag.IncomeChangePercentage</div>
                </div>
                <div class="summary-icon icon-mini">💹</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="summary-card mini-summary p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Bu Ay Gider</div>
                    <h5 class="summary-value text-danger">@String.Format("{0:N2} ₺", ViewBag.ThisMonthExpense)</h5>
                    <div class="summary-sub">Değişim: %@ViewBag.ExpenseChangePercentage</div>
                </div>
                <div class="summary-icon icon-mini">📉</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="summary-card mini-log p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Toplam Log</div>
                    <h5 class="summary-value">@ViewBag.ToplamLog</h5>
                    <div class="summary-sub">Bugün: @ViewBag.BugunkuLog</div>
                </div>
                <div class="summary-icon icon-log">🛡️</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="summary-card mini-log p-4 h-100">
            <div class="d-flex justify-content-between align-items-center gap-3">
                <div>
                    <div class="summary-label">Finans Skoru</div>
                    <h5 class="summary-value">@ViewBag.FinansSkoru</h5>
                    <div class="summary-sub">En yüksek işlem: @String.Format("{0:N2} ₺", ViewBag.EnYuksekIslemTutari)</div>
                </div>
                <div class="summary-icon icon-log">⭐</div>
            </div>
        </div>
    </div>
</div>

<!-- Monthly income and expense analysis chart -->
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="chart-card p-3 p-md-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="section-title">Aylık Gelir / Gider Analizi</h5>
                    <p class="section-subtitle">Aylara göre gelir ve gider değişimini inceleyebilirsin.</p>
                </div>
                <span class="metric-chip chip-info">Aylık Trend</span>
            </div>

            <div class="chart-wrapper chart-wrapper-lg">
                @if (ViewBag.AylikLabels != null && ((List<string>)ViewBag.AylikLabels).Any())
                {
                    <canvas id="monthlyFinanceChart"></canvas>
                }
                else
                {
                    <!-- Empty state shown when no monthly data is available -->
                    <div class="empty-state w-100">
                        <div class="empty-icon">📈</div>
                        <h6 class="fw-bold mb-1">Aylık grafik verisi yok</h6>
                        <p class="text-muted small mb-0">Farklı aylarda kayıt oluştukça grafik burada görünecek.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Finance distribution charts -->
<div id="charts" class="row g-4 mb-4">
    <div class="col-12 col-xl-6">
        <div class="chart-card p-3 p-md-4 h-100">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="section-title">Gelir / Gider Grafiği</h5>
                    <p class="section-subtitle">Finansal dağılımı görsel olarak inceleyebilirsin.</p>
                </div>
                <span class="metric-chip chip-success">Genel Özet</span>
            </div>

            <div class="chart-wrapper">
                @if ((decimal)ViewBag.ToplamGelir + (decimal)ViewBag.ToplamGider > 0)
                {
                    <canvas id="financeChart"></canvas>
                }
                else
                {
                    <!-- Empty state shown when income/expense data is missing -->
                    <div class="empty-state w-100">
                        <div class="empty-icon">📊</div>
                        <h6 class="fw-bold mb-1">Grafik verisi yok</h6>
                        <p class="text-muted small mb-0">Gelir veya gider kaydı eklendiğinde grafik burada görünecek.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="chart-card p-3 p-md-4 h-100">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="section-title">Kategori Bazlı Gider Dağılımı</h5>
                    <p class="section-subtitle">Giderlerin kategorilere göre dağılımını inceleyebilirsin.</p>
                </div>
                <span class="metric-chip chip-warning">Gider Analizi</span>
            </div>

            <div class="chart-wrapper">
                @if (ViewBag.GiderKategoriLabels != null && ((List<string>)ViewBag.GiderKategoriLabels).Any())
                {
                    <canvas id="categoryExpenseChart"></canvas>
                }
                else
                {
                    <!-- Empty state shown when category-based expense data is unavailable -->
                    <div class="empty-state w-100">
                        <div class="empty-icon">🍩</div>
                        <h6 class="fw-bold mb-1">Kategori verisi yok</h6>
                        <p class="text-muted small mb-0">Gider kaydı ve kategori eklendiğinde dağılım grafiği burada görünecek.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Side panels: top categories, recent transactions, and audit logs -->
<div class="row g-4 mb-4">
    <div class="col-12 col-xl-4">
        <div class="soft-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="section-title">Kategori Top List</h5>
                    <p class="section-subtitle">En yüksek gider kategorilerini görüntüle.</p>
                </div>
                <span class="metric-chip chip-danger">Top 5</span>
            </div>

            @if (topCategories != null && topCategories.Any())
            {
                foreach (var item in topCategories)
                {
                    <div class="top-category-row">
                        <div>
                            <div class="fw-semibold">@item.Category</div>
                        </div>
                        <div class="fw-bold text-danger">@item.Total.ToString("N2") ₺</div>
                    </div>
                }
            }
            else
            {
                <!-- Empty state shown when no top categories are available -->
                <div class="empty-state">
                    <div class="empty-icon">📂</div>
                    <h6 class="fw-bold mb-1">Kategori özeti yok</h6>
                    <p class="text-muted small mb-0">Gider verisi oluştuğunda burada görüntülenecek.</p>
                </div>
            }
        </div>
    </div>

    <div class="col-12 col-xl-4" id="recent-transactions">
        <div class="soft-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="section-title">Son İşlemler</h5>
                    <p class="section-subtitle">En son eklenen 3 kayıt</p>
                </div>
                <span class="metric-chip chip-info">Canlı Liste</span>
            </div>

            @if (sonIslemler != null && sonIslemler.Any())
            {
                foreach (var item in sonIslemler)
                {
                    <div class="side-list-item">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <div class="fw-semibold">@item.Date.ToString("dd.MM.yyyy")</div>

                            @if (item.Type == "Gelir")
                            {
                                <span class="badge text-bg-success">Gelir</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger">Gider</span>
                            }
                        </div>

                        <div class="fw-bold mb-2">@item.Amount.ToString("N2") ₺</div>

                        <div class="mb-2">
                            <span class="badge text-bg-secondary">@(string.IsNullOrWhiteSpace(item.Category) ? "Diğer" : item.Category)</span>
                        </div>

                        <div class="text-muted small mb-3">
                            @(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)
                        </div>

                        <!-- Link to transaction details -->
                        @Html.ActionLink("Detay", "Details", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-dark w-100" })
                    </div>
                }
            }
            else
            {
                <!-- Empty state shown when no recent transactions exist -->
                <div class="empty-state">
                    <div class="empty-icon">🧾</div>
                    <h6 class="fw-bold mb-1">Son işlem bulunamadı</h6>
                    <p class="text-muted small mb-0">Henüz görüntülenecek bir kayıt yok.</p>
                </div>
            }
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="soft-card p-4 h-100">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="section-title">Audit Log Aktiviteleri</h5>
                    <p class="section-subtitle">Son sistem hareketlerini görüntüle.</p>
                </div>
                <span class="metric-chip chip-warning">Güvenlik</span>
            </div>

            <!-- Summary chips for log action counts -->
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="metric-chip chip-success">Create: @ViewBag.CreateLogCount</span>
                <span class="metric-chip chip-warning">Update: @ViewBag.UpdateLogCount</span>
                <span class="metric-chip chip-danger">Delete: @ViewBag.DeleteLogCount</span>
            </div>

            @if (sonLoglar != null && sonLoglar.Any())
            {
                foreach (var log in sonLoglar)
                {
                    // Resolve visual class based on the log action type
                    var activityClass = "activity-item";
                    if (log.Action == "Create") { activityClass += " activity-create"; }
                    else if (log.Action == "Update") { activityClass += " activity-update"; }
                    else { activityClass += " activity-delete"; }

                    <div class="@activityClass">
                        <div class="d-flex justify-content-between align-items-start gap-2">
                            <div class="fw-semibold">@log.Action</div>
                            <div class="text-muted small">@(log.LogDate.HasValue ? log.LogDate.Value.ToString("dd.MM.yyyy HH:mm") : "-")</div>
                        </div>
                        <div class="text-muted small mt-1">@log.Description</div>
                    </div>
                }
            }
            else
            {
                <!-- Empty state shown when there are no log records -->
                <div class="empty-state">
                    <div class="empty-icon">🛡️</div>
                    <h6 class="fw-bold mb-1">Log bulunamadı</h6>
                    <p class="text-muted small mb-0">Henüz sistem hareketi kaydı yok.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Main transaction table -->
<div id="transactions" class="table-shell">
    <div class="p-4 border-bottom">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <h5 class="section-title mb-1">İşlem Tablosu</h5>
                <p class="section-subtitle mb-0">@Model.Count() kayıt listeleniyor</p>
            </div>
            <span class="metric-chip chip-info">@filterSummary</span>
        </div>
    </div>

    <div class="table-responsive">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Tarih</th>
                        <th>Kategori</th>
                        <th>Tip</th>
                        <th>Tutar</th>
                        <th>Açıklama</th>
                        <th style="width: 220px;" class="pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <!-- Transaction date -->
                            <td class="ps-4">@item.Date.ToString("dd.MM.yyyy")</td>

                            <!-- Transaction category -->
                            <td>
                                <span class="badge text-bg-secondary">@(string.IsNullOrWhiteSpace(item.Category) ? "Diğer" : item.Category)</span>
                            </td>

                            <!-- Transaction type badge -->
                            <td>
                                @if (item.Type == "Gelir")
                                {
                                    <span class="badge rounded-pill text-bg-success">Gelir</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill text-bg-danger">Gider</span>
                                }
                            </td>

                            <!-- Transaction amount -->
                            <td class="fw-semibold">@item.Amount.ToString("N2") ₺</td>

                            <!-- Transaction description -->
                            <td>@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>

                            <!-- Row action buttons -->
                            <td class="pe-4">
                                <div class="action-stack">
                                    @Html.ActionLink("Detay", "Details", new { id = item.Id }, new { @class = "btn btn-outline-info btn-sm" })
                                    @Html.ActionLink("Düzenle", "Edit", new { id = item.Id }, new { @class = "btn btn-outline-warning btn-sm" })

                                    <!-- Delete button opens a confirmation modal -->
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm w-100 open-delete-alert"
                                            data-id="@item.Id"
                                            data-category="@(string.IsNullOrWhiteSpace(item.Category) ? "Diğer" : item.Category)"
                                            data-amount="@item.Amount.ToString("N2")"
                                            data-date="@item.Date.ToString("dd.MM.yyyy")">
                                        Sil
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <!-- Empty state shown when the filter returns no records -->
            <div class="p-4">
                <div class="alert alert-warning mb-0">
                    <strong>Kayıt bulunamadı.</strong><br />
                    Bu filtreye ait kayıt bulunamadı.
                </div>
            </div>
        }
    </div>
</div>

<!-- Hidden form used to submit delete requests securely -->
@using (Html.BeginForm("Delete", "Finance", FormMethod.Post, new { id = "deleteForm" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteItemId" />
}

@section Scripts {
    <script>
        // Monthly chart labels and dataset values passed from the server
        const aylikLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AylikLabels));
        const aylikGelirler = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AylikGelirler));
        const aylikGiderler = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AylikGiderler));

        // Monthly finance chart canvas reference
        const monthlyCtx = document.getElementById('monthlyFinanceChart');

        // Render monthly income/expense bar chart only when data exists
        if (monthlyCtx && aylikLabels.length > 0) {
            new Chart(monthlyCtx, {
                type: 'bar',
                data: {
                    labels: aylikLabels,
                    datasets: [
                        {
                            label: 'Gelir',
                            data: aylikGelirler,
                            backgroundColor: '#16a34a',
                            borderRadius: 8
                        },
                        {
                            label: 'Gider',
                            data: aylikGiderler,
                            backgroundColor: '#dc2626',
                            borderRadius: 8
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: {
                            callbacks: {
                                // Format tooltip values as Turkish currency
                                label: function (context) {
                                    return context.dataset.label + ': ' + context.raw.toLocaleString('tr-TR') + ' ₺';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                // Format y-axis labels as currency values
                                callback: function (value) {
                                    return value.toLocaleString('tr-TR') + ' ₺';
                                }
                            }
                        }
                    }
                }
            });
        }

        // Total income and expense values used in the finance pie chart
        const gelir = @Html.Raw(Convert.ToDecimal(ViewBag.ToplamGelir).ToString(System.Globalization.CultureInfo.InvariantCulture));
        const gider = @Html.Raw(Convert.ToDecimal(ViewBag.ToplamGider).ToString(System.Globalization.CultureInfo.InvariantCulture));
        const toplam = gelir + gider;

        // Finance summary chart canvas reference
        const financeCtx = document.getElementById('financeChart');

        // Render finance pie chart only when at least one value is greater than zero
        if (financeCtx && toplam > 0) {
            new Chart(financeCtx, {
                type: 'pie',
                data: {
                    labels: ['Gelir', 'Gider'],
                    datasets: [{
                        data: [gelir, gider],
                        backgroundColor: ['#16a34a', '#dc2626'],
                        borderWidth: 2
                    }]
                },
                plugins: [ChartDataLabels],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: {
                            callbacks: {
                                // Show value and percentage in tooltip
                                label: function (context) {
                                    const value = context.raw;
                                    const percentage = ((value / toplam) * 100).toFixed(1);
                                    return context.label + ': ' + value.toLocaleString('tr-TR') + ' ₺' + ' (%' + percentage + ')';
                                }
                            }
                        },
                        datalabels: {
                            color: '#fff',
                            font: {
                                weight: 'bold',
                                size: 13
                            },
                            // Show percentage labels on the chart slices
                            formatter: function (value) {
                                return '%' + ((value / toplam) * 100).toFixed(1);
                            }
                        }
                    }
                }
            });
        }

        // Category-based expense chart data
        const categoryLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GiderKategoriLabels));
        const categoryTotals = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GiderKategoriTotals));
        const categoryToplam = categoryTotals.reduce((a, b) => a + b, 0);

        // Expense by category chart canvas reference
        const categoryCtx = document.getElementById('categoryExpenseChart');

        // Render doughnut chart when category data is available
        if (categoryCtx && categoryLabels.length > 0 && categoryToplam > 0) {
            new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: categoryLabels,
                    datasets: [{
                        data: categoryTotals,
                        backgroundColor: [
                            '#ef4444',
                            '#f97316',
                            '#f59e0b',
                            '#10b981',
                            '#3b82f6',
                            '#8b5cf6',
                            '#6b7280'
                        ],
                        borderWidth: 2
                    }]
                },
                plugins: [ChartDataLabels],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '48%',
                    plugins: {
                        legend: { position: 'bottom' },
                        tooltip: {
                            callbacks: {
                                // Show category value and percentage in tooltip
                                label: function (context) {
                                    const value = context.raw;
                                    const percentage = ((value / categoryToplam) * 100).toFixed(1);
                                    return context.label + ': ' + value.toLocaleString('tr-TR') + ' ₺' + ' (%' + percentage + ')';
                                }
                            }
                        },
                        datalabels: {
                            color: '#fff',
                            font: {
                                weight: 'bold',
                                size: 12
                            },
                            // Show percentage labels directly on the chart
                            formatter: function (value) {
                                return '%' + ((value / categoryToplam) * 100).toFixed(1);
                            }
                        }
                    }
                }
            });
        }

        // Initialize delete confirmation behavior after DOM content is loaded
        document.addEventListener("DOMContentLoaded", function () {
            const deleteButtons = document.querySelectorAll(".open-delete-alert");
            const deleteForm = document.getElementById("deleteForm");
            const deleteItemIdInput = document.getElementById("deleteItemId");

            // Attach click event to each delete button
            deleteButtons.forEach(button => {
                button.addEventListener("click", function () {
                    const id = this.dataset.id || "";
                    const date = this.dataset.date || "-";
                    const category = this.dataset.category || "-";
                    const amount = this.dataset.amount || "0,00";

                    // Show SweetAlert confirmation modal with transaction details
                    Swal.fire({
                        title: 'Kaydı Sil',
                        html: `
                            <div style="text-align:left; margin-top:10px;">
                                <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:16px; padding:16px;">
                                    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                                        <span style="color:#64748b; font-weight:600;">Tarih</span>
                                        <strong style="color:#0f172a;">${date}</strong>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                                        <span style="color:#64748b; font-weight:600;">Kategori</span>
                                        <strong style="color:#0f172a;">${category}</strong>
                                    </div>
                                    <div style="display:flex; justify-content:space-between;">
                                        <span style="color:#64748b; font-weight:600;">Tutar</span>
                                        <strong style="color:#dc2626;">${amount} ₺</strong>
                                    </div>
                                </div>

                                <div style="margin-top:14px; background:#fef2f2; border:1px solid #fecaca; color:#b91c1c; border-radius:14px; padding:12px 14px; font-size:14px;">
                                    <strong>Dikkat:</strong> Bu kayıt silindiğinde geri getirilemez.
                                </div>
                            </div>
                        `,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Evet, Sil',
                        cancelButtonText: 'Vazgeç',
                        reverseButtons: true,
                        focusCancel: true,
                        buttonsStyling: false,
                        customClass: {
                            popup: 'finance-swal-popup',
                            title: 'finance-swal-title',
                            confirmButton: 'finance-swal-confirm',
                            cancelButton: 'finance-swal-cancel'
                        }
                    }).then((result) => {
                        // Submit delete form only if the user confirms the action
                        if (result.isConfirmed) {
                            deleteItemIdInput.value = id;
                            deleteForm.submit();
                        }
                    });
                });
            });
        });
    </script>
}