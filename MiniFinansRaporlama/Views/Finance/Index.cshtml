@model IEnumerable<MiniFinansRaporlama.Models.Transactions>

@{
    // Page title
    ViewBag.Title = "Finansal İşlemler";

    // Recent transactions list shown in the right panel
    var sonIslemler = ViewBag.SonIslemler as List<MiniFinansRaporlama.Models.Transactions>;
}

@section Styles {
    <style>
        /* Wrapper used for chart areas */
        .chart-wrapper {
            position: relative;
            width: 100%;
            min-height: 260px;
            height: 260px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

            /* Canvas size limits inside chart wrapper */
            .chart-wrapper canvas {
                max-width: 320px;
                width: 100% !important;
                height: 100% !important;
            }

        /* Chart height for tablet and larger screens */
        @@media (min-width: 768px) {
            .chart-wrapper {
                min-height: 320px;
                height: 320px;
            }

                .chart-wrapper canvas {
                    max-width: 360px;
                }
        }

        /* Chart height for large screens */
        @@media (min-width: 1200px) {
            .chart-wrapper {
                min-height: 340px;
                height: 340px;
            }

                .chart-wrapper canvas {
                    max-width: 380px;
                }
        }
    </style>
}

<!-- Page header and create transaction button -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <!-- Page title -->
        <h2 class="fw-bold mb-1">Finansal İşlemler</h2>

        <!-- Short description for the user -->
        <p class="text-muted mb-0">Gelir ve gider kayıtlarını buradan yönetebilirsin.</p>
    </div>

    <!-- Navigation to create transaction page -->
    <div>
        @Html.ActionLink("Yeni İşlem Ekle", "Create", null, new { @class = "btn btn-primary rounded-pill px-4 shadow-sm" })
    </div>
</div>

<!-- Filter section -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
                <!-- Filter card title -->
                <h5 class="mb-1">Filtreleme</h5>

                <!-- Filter card description -->
                <p class="text-muted mb-0 small">Tarih ve kategoriye göre işlemleri filtreleyebilirsin.</p>
            </div>
        </div>

        <!-- Filter form -->
        @using (Html.BeginForm("Index", "Finance", FormMethod.Get, new { @class = "row g-3 align-items-end" }))
        {
            <!-- Start date -->
            <div class="col-12 col-md-3">
                <label for="startDate" class="form-label fw-semibold">Başlangıç Tarihi</label>
                <input type="date"
                       name="startDate"
                       id="startDate"
                       class="form-control"
                       value="@(ViewBag.StartDate != null ? ((DateTime)ViewBag.StartDate).ToString("yyyy-MM-dd") : "")" />
            </div>

            <!-- End date -->
            <div class="col-12 col-md-3">
                <label for="endDate" class="form-label fw-semibold">Bitiş Tarihi</label>
                <input type="date"
                       name="endDate"
                       id="endDate"
                       class="form-control"
                       value="@(ViewBag.EndDate != null ? ((DateTime)ViewBag.EndDate).ToString("yyyy-MM-dd") : "")" />
            </div>

            <!-- Category selection -->
            <div class="col-12 col-md-3">
                <label for="category" class="form-label fw-semibold">Kategori</label>
                <select name="category" id="category" class="form-select">
                    <option value="">Tüm Kategoriler</option>
                    <option value="Maaş" @(ViewBag.Category == "Maaş" ? "selected" : "")>Maaş</option>
                    <option value="Ek Gelir" @(ViewBag.Category == "Ek Gelir" ? "selected" : "")>Ek Gelir</option>
                    <option value="Market" @(ViewBag.Category == "Market" ? "selected" : "")>Market</option>
                    <option value="Fatura" @(ViewBag.Category == "Fatura" ? "selected" : "")>Fatura</option>
                    <option value="Ulaşım" @(ViewBag.Category == "Ulaşım" ? "selected" : "")>Ulaşım</option>
                    <option value="Eğitim" @(ViewBag.Category == "Eğitim" ? "selected" : "")>Eğitim</option>
                    <option value="Diğer" @(ViewBag.Category == "Diğer" ? "selected" : "")>Diğer</option>
                </select>
            </div>

            <!-- Filter action buttons -->
            <div class="col-12 col-md-3">
                <div class="d-grid d-sm-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Filtrele</button>
                    <a href="@Url.Action("Index", "Finance")" class="btn btn-outline-secondary px-4">Temizle</a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Summary dashboard cards -->
<div id="dashboard" class="row g-3 mb-4">

    <!-- Total income card -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small mb-1">Toplam Gelir</p>
                    <h4 class="fw-bold text-success mb-0">@String.Format("{0:N2} ₺", ViewBag.ToplamGelir)</h4>
                </div>
                <div class="fs-1 text-success opacity-75">💰</div>
            </div>
        </div>
    </div>

    <!-- Total expense card -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small mb-1">Toplam Gider</p>
                    <h4 class="fw-bold text-danger mb-0">@String.Format("{0:N2} ₺", ViewBag.ToplamGider)</h4>
                </div>
                <div class="fs-1 text-danger opacity-75">💸</div>
            </div>
        </div>
    </div>

    <!-- Net balance card -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small mb-1">Net Bakiye</p>
                    <h4 class="fw-bold mb-0 @(ViewBag.NetBakiye >= 0 ? "text-success" : "text-danger")">
                        @String.Format("{0:N2} ₺", ViewBag.NetBakiye)
                    </h4>
                </div>
                <div class="fs-1 text-primary opacity-75">📊</div>
            </div>
        </div>
    </div>

    <!-- Transaction count card -->
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <p class="text-muted small mb-1">Toplam İşlem</p>
                    <h4 class="fw-bold mb-0">@ViewBag.IslemSayisi</h4>
                </div>
                <div class="fs-1 text-dark opacity-75">🧾</div>
            </div>
        </div>
    </div>

</div>

<!-- Charts and right-side panel -->
<div class="row g-4 mb-4">

    <!-- Left section for charts -->
    <div id="charts" class="col-12 col-xl-9">
        <div class="row g-4">

            <!-- Income / expense pie chart -->
            <div class="col-12">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                            <div>
                                <h5 class="mb-1 fw-bold">Gelir / Gider Grafiği</h5>
                                <p class="text-muted mb-0 small">Finansal dağılımı görsel olarak inceleyebilirsin.</p>
                            </div>
                            <span class="badge text-bg-light border">Genel Özet</span>
                        </div>

                        <div class="chart-wrapper">
                            @if ((decimal)ViewBag.ToplamGelir + (decimal)ViewBag.ToplamGider > 0)
                            {
                                <canvas id="financeChart"></canvas>
                            }
                            else
                            {
                                <!-- Message shown when there is no chart data -->
                                <div class="text-center w-100">
                                    <div class="fs-1 mb-2">📊</div>
                                    <h6 class="fw-bold mb-1">Grafik verisi yok</h6>
                                    <p class="text-muted small mb-0">Gelir veya gider kaydı eklendiğinde grafik burada görünecek.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Expense distribution by category chart -->
            <div class="col-12">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                            <div>
                                <h5 class="mb-1 fw-bold">Kategori Bazlı Gider Dağılımı</h5>
                                <p class="text-muted mb-0 small">Giderlerin kategorilere göre dağılımını inceleyebilirsin.</p>
                            </div>
                            <span class="badge text-bg-light border">Gider Analizi</span>
                        </div>

                        <div class="chart-wrapper">
                            @if (ViewBag.GiderKategoriLabels != null && ((List<string>)ViewBag.GiderKategoriLabels).Any())
                            {
                                <canvas id="categoryExpenseChart"></canvas>
                            }
                            else
                            {
                                <!-- Message shown when there is no category data -->
                                <div class="text-center w-100">
                                    <div class="fs-1 mb-2">🍩</div>
                                    <h6 class="fw-bold mb-1">Kategori verisi yok</h6>
                                    <p class="text-muted small mb-0">Gider kaydı ve kategori eklendiğinde dağılım grafiği burada görünecek.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Future feature: monthly income / expense chart
                 This section is intentionally kept commented out
                 so it can be enabled later as an advanced feature.
            -->
            <!-- Aylık Gelir / Gider
            <div class="col-12">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                            <div>
                                <h5 class="mb-1 fw-bold">Aylık Gelir / Gider Analizi</h5>
                                <p class="text-muted mb-0 small">Aylara göre gelir ve gider değişimini inceleyebilirsin.</p>
                            </div>
                            <span class="badge text-bg-light border">Aylık Trend</span>
                        </div>

                        <div class="chart-wrapper">
                            @if (ViewBag.AylikLabels != null && ((List<string>)ViewBag.AylikLabels).Any())
                            {
                                <canvas id="monthlyFinanceChart"></canvas>
                            }
                            else
                            {
                                <div class="text-center w-100">
                                    <div class="fs-1 mb-2">📈</div>
                                    <h6 class="fw-bold mb-1">Aylık grafik verisi yok</h6>
                                    <p class="text-muted small mb-0">Farklı aylarda kayıt oluştukça grafik burada görünecek.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            -->

        </div>
    </div>

    <!-- Right section for recent transactions -->
    <div id="recent-transactions" class="col-12 col-xl-3">
        <div class="d-flex flex-column gap-4">

            <!-- Recent transactions card -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-3 p-md-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h5 class="mb-1 fw-bold">Son İşlemler</h5>
                            <p class="text-muted small mb-0">En son eklenen 5 kayıt</p>
                        </div>
                    </div>

                    @if (sonIslemler != null && sonIslemler.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var item in sonIslemler)
                            {
                                <!-- Single recent transaction item -->
                                <div class="border rounded-3 p-3 bg-light">
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">

                                        <!-- Transaction date -->
                                        <div class="fw-semibold">
                                            @(item.Date != null ? item.Date.ToString("dd.MM.yyyy") : "")
                                        </div>

                                        <!-- Badge based on transaction type -->
                                        @if (item.Type == "Gelir")
                                        {
                                            <span class="badge text-bg-success">Gelir</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">Gider</span>
                                        }
                                    </div>

                                    <!-- Transaction amount -->
                                    <div class="fw-bold mb-2">
                                        @item.Amount.ToString("N2") ₺
                                    </div>

                                    <!-- Transaction category -->
                                    <div class="mb-2">
                                        <span class="badge text-bg-secondary">@item.Category</span>
                                    </div>

                                    <!-- Transaction description -->
                                    <div class="text-muted small mb-3">
                                        @item.Description
                                    </div>

                                    <!-- Link to details page -->
                                    <div>
                                        @Html.ActionLink("Detay", "Details", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-dark w-100" })
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Empty state when there are no recent transactions -->
                        <div class="text-center py-4">
                            <div class="fs-1 mb-2">🧾</div>
                            <h6 class="fw-bold mb-1">Son işlem bulunamadı</h6>
                            <p class="text-muted small mb-0">Henüz görüntülenecek bir kayıt yok.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Main transactions table -->
<div id="transactions" class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Tarih</th>
                            <th>Kategori</th>
                            <th>Tip</th>
                            <th>Tutar</th>
                            <th>Açıklama</th>
                            <th style="width: 180px;" class="pe-3">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <!-- Transaction date -->
                                <td class="ps-3">@(item.Date != null ? item.Date.ToString("dd.MM.yyyy") : "")</td>

                                <!-- Transaction category -->
                                <td><span class="badge text-bg-secondary">@item.Category</span></td>

                                <!-- Transaction type -->
                                <td>
                                    @if (item.Type == "Gelir")
                                    {
                                        <span class="badge rounded-pill text-bg-success">Gelir</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill text-bg-danger">Gider</span>
                                    }
                                </td>

                                <!-- Transaction amount -->
                                <td class="fw-semibold">@item.Amount.ToString("N2") ₺</td>

                                <!-- Transaction description -->
                                <td>@item.Description</td>

                                <!-- Action buttons -->
                                <td class="pe-3">
                                    <div class="d-grid gap-2 action-stack">
                                        @Html.ActionLink("Detay", "Details", new { id = item.Id }, new { @class = "btn btn-outline-info btn-sm" })
                                        @Html.ActionLink("Düzenle", "Edit", new { id = item.Id }, new { @class = "btn btn-outline-warning btn-sm" })
                                        @Html.ActionLink("Sil", "Delete", new { id = item.Id }, new { @class = "btn btn-outline-danger btn-sm" })
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <!-- Warning shown when no records are found -->
            <div class="p-4">
                <div class="alert alert-warning d-flex align-items-center mb-0" role="alert">
                    <div>
                        <strong>Kayıt bulunamadı.</strong><br />
                        Bu filtreye ait kayıt bulunamadı.
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Transfer monthly chart data from ViewBag to JavaScript
        const aylikLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AylikLabels));
        const aylikGelirler = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AylikGelirler));
        const aylikGiderler = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.AylikGiderler));

        // Get monthly chart canvas element
        const monthlyCtx = document.getElementById('monthlyFinanceChart');

        // Create monthly chart if canvas exists and data is available
        if (monthlyCtx && aylikLabels.length > 0) {
            new Chart(monthlyCtx, {
                type: 'bar',
                data: {
                    labels: aylikLabels,
                    datasets: [
                        {
                            label: 'Gelir',
                            data: aylikGelirler,
                            backgroundColor: '#198754',
                            borderRadius: 8
                        },
                        {
                            label: 'Gider',
                            data: aylikGiderler,
                            backgroundColor: '#dc3545',
                            borderRadius: 8
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function (value) {
                                    return value.toLocaleString('tr-TR') + ' ₺';
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return context.dataset.label + ': ' +
                                        context.raw.toLocaleString('tr-TR') + ' ₺';
                                }
                            }
                        }
                    }
                }
            });
        }

        // Transfer total income and total expense values to JavaScript
        const gelir = @Html.Raw(Convert.ToDecimal(ViewBag.ToplamGelir).ToString(System.Globalization.CultureInfo.InvariantCulture));
        const gider = @Html.Raw(Convert.ToDecimal(ViewBag.ToplamGider).ToString(System.Globalization.CultureInfo.InvariantCulture));
        const toplam = gelir + gider;

        // Get pie chart canvas element
        const financeCtx = document.getElementById('financeChart');

        // Create pie chart if data is available
        if (financeCtx && toplam > 0) {
            new Chart(financeCtx, {
                type: 'pie',
                data: {
                    labels: ['Gelir', 'Gider'],
                    datasets: [{
                        data: [gelir, gider],
                        backgroundColor: ['#198754', '#dc3545'],
                        borderWidth: 2
                    }]
                },
                plugins: [ChartDataLabels],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const value = context.raw;
                                    const percentage = ((value / toplam) * 100).toFixed(1);

                                    return context.label + ': ' +
                                        value.toLocaleString('tr-TR') + ' ₺' +
                                        ' (%' + percentage + ')';
                                }
                            }
                        },
                        datalabels: {
                            color: '#fff',
                            font: {
                                weight: 'bold',
                                size: 14
                            },
                            formatter: function (value) {
                                const percentage = ((value / toplam) * 100).toFixed(1);
                                return '%' + percentage;
                            }
                        }
                    }
                }
            });
        }

        // Transfer expense by category data to JavaScript
        const categoryLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GiderKategoriLabels));
        const categoryTotals = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GiderKategoriTotals));
        const categoryToplam = categoryTotals.reduce((a, b) => a + b, 0);

        // Get doughnut chart canvas element
        const categoryCtx = document.getElementById('categoryExpenseChart');

        // Create category-based expense chart if data is available
        if (categoryCtx && categoryLabels.length > 0 && categoryToplam > 0) {
            new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: categoryLabels,
                    datasets: [{
                        data: categoryTotals,
                        backgroundColor: [
                            '#dc3545',
                            '#fd7e14',
                            '#ffc107',
                            '#20c997',
                            '#0d6efd',
                            '#6f42c1',
                            '#6c757d'
                        ],
                        borderWidth: 2
                    }]
                },
                plugins: [ChartDataLabels],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '45%',
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const value = context.raw;
                                    const percentage = ((value / categoryToplam) * 100).toFixed(1);

                                    return context.label + ': ' +
                                        value.toLocaleString('tr-TR') + ' ₺' +
                                        ' (%' + percentage + ')';
                                }
                            }
                        },
                        datalabels: {
                            color: '#fff',
                            font: {
                                weight: 'bold',
                                size: 13
                            },
                            formatter: function (value) {
                                const percentage = ((value / categoryToplam) * 100).toFixed(1);
                                return '%' + percentage;
                            }
                        }
                    }
                }
            });
        }
    </script>
}