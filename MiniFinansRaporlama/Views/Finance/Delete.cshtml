@model MiniFinansRaporlama.Models.Transactions

@{
    ViewBag.Title = "İşlem Sil";
}

<!-- Page header and back button -->
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="mb-1 text-danger">İşlem Sil</h2>
        <p class="text-muted mb-0">Bu kaydı silmeden önce bilgileri kontrol et.</p>
    </div>

    <!-- Button to return to list page -->
    <div>
        @Html.ActionLink("Listeye Dön", "Index", null, new { @class = "btn btn-outline-secondary" })
    </div>
</div>

<!-- Main delete confirmation card -->
<div class="card shadow-sm border-0">
    <div class="card-body p-4">

        <!-- Warning message shown before deletion -->
        <div class="alert alert-warning mb-4">
            Bu kaydı silmek istediğine emin misin? Bu işlem geri alınamaz.
        </div>

        <!-- Transaction details shown before delete action -->
        <div class="row g-3">

            <!-- Transaction date -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Tarih</label>
                <div class="form-control bg-light">
                    @(Model.Date != null ? Model.Date.ToString("dd.MM.yyyy") : "")
                </div>
            </div>

            <!-- Transaction category -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Kategori</label>
                <div class="form-control bg-light">
                    @Model.Category
                </div>
            </div>

            <!-- Transaction type -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Tip</label>
                <div class="form-control bg-light">
                    @if (Model.Type == "Gelir")
                    {
                        <span class="badge text-bg-success">Gelir</span>
                    }
                    else
                    {
                        <span class="badge text-bg-danger">Gider</span>
                    }
                </div>
            </div>

            <!-- Transaction amount -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Tutar</label>
                <div class="form-control bg-light">
                    @Model.Amount.ToString("N2") ₺
                </div>
            </div>

            <!-- Transaction description -->
            <div class="col-12">
                <label class="form-label fw-semibold">Açıklama</label>
                <div class="form-control bg-light" style="min-height: 90px;">
                    @Model.Description
                </div>
            </div>
        </div>

        @* Form used to submit delete request *@
        @using (Html.BeginForm("Delete", "Finance", FormMethod.Post, new { id = "deleteForm" }))
        {
            @Html.AntiForgeryToken()

            <!-- Action buttons -->
            <div class="d-flex flex-column flex-sm-row gap-2 mt-4">

                @* Delete button triggers SweetAlert confirmation before submit *@
                <button type="button" class="btn btn-danger" id="deleteBtn">
                    Kaydı Sil
                </button>

                @* Cancel button returns to index page *@
                @Html.ActionLink("Vazgeç", "Index", null, new { @class = "btn btn-outline-dark" })
            </div>
        }
        @* End delete form *@

    </div>
</div>

<script>
    // Adds final confirmation before submitting delete form
    document.getElementById("deleteBtn").addEventListener("click", function () {

        Swal.fire({
            title: "Emin misin?",
            text: "Bu işlem geri alınamaz!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc3545",
            cancelButtonColor: "#6c757d",
            confirmButtonText: "Evet, Sil",
            cancelButtonText: "Vazgeç"
        }).then((result) => {

            // Submit form only if user confirms deletion
            if (result.isConfirmed) {
                document.getElementById("deleteForm").submit();
            }

        });

    });
</script>