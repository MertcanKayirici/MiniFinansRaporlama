<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Page title, each view provides its own ViewBag.Title -->
    <title>@ViewBag.Title - Mini Finans App</title>

    <!-- Bootstrap 5 stylesheet -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        /* Enables smooth scrolling for anchor navigation */
        html {
            scroll-behavior: smooth;
        }

        /* Adds top spacing so fixed navbar does not overlap content */
        body {
            background-color: #f8f9fa;
            padding-top: 70px;
        }

        /* Brand text style in navbar */
        .navbar-brand {
            font-weight: 700;
            letter-spacing: .3px;
        }

        /* Shared button-like style for navbar links */
        .nav-btn {
            padding: .45rem .9rem;
            border-radius: .6rem;
            transition: all .2s ease;
        }

            /* Hover effect for navbar buttons */
            .nav-btn:hover {
                background: rgba(255,255,255,.15);
            }

        /* Active section link style */
        .section-link.active {
            background: rgba(255,255,255,.2);
            font-weight: 600;
        }

        /* Special style for create transaction button */
        .nav-create {
            background: #0d6efd;
        }

            /* Hover state for create transaction button */
            .nav-create:hover {
                background: #0b5ed7;
            }

        /* Vertical spacing for the main page section */
        .page-section {
            padding-top: 2rem;
            padding-bottom: 2rem;
        }

        /* Shared card style used across pages */
        .page-card {
            background: #ffffff;
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, .06);
        }

        /* Helper style for dashboard cards */
        .stat-card {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 0.5rem 1.25rem rgba(0, 0, 0, .08);
        }

        /* Prevents table headers from wrapping */
        .table thead th {
            white-space: nowrap;
        }

        /* Makes action buttons full width on mobile */
        .action-stack .btn {
            width: 100%;
        }

        /* Smooth transition when navbar hides or shows */
        #mainNavbar {
            transition: top 0.3s ease;
        }

        /* Prevent anchor targets from staying under navbar */
        #dashboard,
        #charts,
        #transactions,
        #recent-transactions {
            scroll-margin-top: 90px;
        }

        /* Extra visual style for active section link */
        .section-link.active {
            color: #ffffff !important;
            font-weight: 600;
            position: relative;
        }

        /* Align action buttons horizontally on tablet and larger screens */
        @@media (min-width: 768px) {
            .action-stack {
                display: flex;
                gap: .5rem;
                flex-wrap: wrap;
            }

                .action-stack .btn {
                    width: auto;
                }
        }
    </style>

    <!-- Renders page-specific styles if provided -->
    @RenderSection("Styles", required: false)
</head>
<body>

    <!--
        Top navbar
        - Stays fixed at the top of the page
        - Works as a collapsible menu on mobile
        - Provides quick access to main dashboard sections
    -->
    <nav id="mainNavbar" class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm fixed-top">
        <div class="container">

            <!-- Application brand / home link -->
            @Html.ActionLink("Mini Finans App", "Index", "Finance", null, new { @class = "navbar-brand" })

            <!-- Hamburger menu button for mobile view -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainMenu"
                    aria-controls="mainMenu"
                    aria-expanded="false"
                    aria-label="Menüyü Aç">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Navbar menu area -->
            <div class="collapse navbar-collapse" id="mainMenu">
                <ul class="navbar-nav ms-auto gap-2">

                    <!-- In-page navigation links -->
                    <li class="nav-item">
                        <a class="nav-link nav-btn section-link" href="/Finance/Index#dashboard">Dashboard</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-btn section-link" href="/Finance/Index#charts">Grafikler</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-btn section-link" href="/Finance/Index#recent-transactions">Son İşlemler</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-btn section-link" href="/Finance/Index#transactions">İşlemler</a>
                    </li>

                    <!-- Main link for navigating to create transaction page -->
                    <li class="nav-item">
                        @Html.ActionLink("Yeni İşlem", "Create", "Finance", null,
                        new { @class = "nav-link nav-btn nav-create" })
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <!-- Main content area -->
    <main class="container page-section">
        <div class="page-card">

            <!-- Renders the body content of each page -->
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="border-top bg-white py-3 text-center text-muted small">
        Mini Finans App • @DateTime.Now.Year
    </footer>

    <!-- Shared JavaScript libraries -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            /* Navbar hide/show behavior on scroll */
            let lastScrollTop = 0;
            const navbar = document.getElementById("mainNavbar");

            window.addEventListener("scroll", function () {
                let scrollTop = window.pageYOffset || document.documentElement.scrollTop;

                if (scrollTop > lastScrollTop && scrollTop > 100) {
                    navbar.style.top = "-80px";
                } else {
                    navbar.style.top = "0";
                }

                lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
            });

            /* Closes mobile menu when a navigation link is clicked */
            const navbarCollapse = document.getElementById("mainMenu");
            const allNavLinks = document.querySelectorAll(".navbar-collapse .nav-link");

            allNavLinks.forEach(function (link) {
                link.addEventListener("click", function () {
                    if (window.innerWidth < 992) {
                        const bsCollapse =
                            bootstrap.Collapse.getInstance(navbarCollapse) ||
                            new bootstrap.Collapse(navbarCollapse, { toggle: false });

                        bsCollapse.hide();
                    }
                });
            });

            /* Highlights the active section link while scrolling */
            const sectionLinks = document.querySelectorAll(".section-link");

            const sections = ["dashboard", "charts", "recent-transactions", "transactions"]
                .map(function (id) { return document.getElementById(id); })
                .filter(function (section) { return section !== null; });

            function setActiveSection() {
                let scrollPosition = window.scrollY + 120;
                let currentId = "";

                sections.forEach(function (section) {
                    if (scrollPosition >= section.offsetTop) {
                        currentId = section.id;
                    }
                });

                sectionLinks.forEach(function (link) {
                    link.classList.remove("active");

                    const href = link.getAttribute("href");
                    if (href && href.indexOf("#" + currentId) !== -1) {
                        link.classList.add("active");
                    }
                });
            }

            /* Sets active section on first page load */
            setActiveSection();

            /* Updates active section during scroll */
            window.addEventListener("scroll", setActiveSection);
        });
    </script>

    <!-- Renders page-specific scripts if provided -->
    @RenderSection("Scripts", required: false)
</body>
</html>